BOT_TOKEN=your_telegram_bot_token_here

# Database Config
POSTGRES_USER=botuser
POSTGRES_PASSWORD=your_super_secure_password_here
POSTGRES_DB=rentbot
DATABASE_URL=postgresql+asyncpg://botuser:your_super_secure_password_here@db:5432/rentbot

PROXY_URL=http://127.0.0.1:8080

# Yookassa Integration
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_SECRET_KEY=your_secret_key_here

# Admin IDs (comma-separated Telegram user IDs)
ADMIN_IDS=150190533,506450098

# Redis
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@redis:6379/0

# Webhook
USE_WEBHOOK=False
WEBHOOK_URL=https://your-domain.com/webhook

# Security: Telegram webhook secret (generate with: openssl rand -hex 32)
WEBHOOK_SECRET=your_random_webhook_secret_here

# Admin dashboard password (leave empty to disable auth in dev)
ADMIN_DASHBOARD_PASSWORD=your_dashboard_password_here
